{
  "name": "@tekojs/http",
  "version": "1.0.0",
  "description": "HTTP functionalities for the Teko ecosystem",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "files": [
    "dist",
    "!dist/tests",
    "!dist/**/*.test.*",
    "dist/**/*.d.ts",
    "dist/**/*.js"
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/tekojs/http.git"
  },
  "homepage": "https://github.com/tekojs/http#readme",
  "bugs": {
    "url": "https://github.com/tekojs/http/issues"
  },
  "scripts": {
    "pretest": "npm run lint",
    "test": "c8 npm run quick:test",
    "lint": "eslint .",
    "format": "prettier --write .",
    "typecheck": "tsc --noEmit",
    "clean": "del-cli dist",
    "precompile": "npm run lint && npm run clean",
    "compile": "tsup-node && tsc --emitDeclarationOnly --declaration",
    "build": "npm run compile",
    "version": "npm run build",
    "prepublishOnly": "npm run build",
    "quick:test": "node --import=ts-node-maintained/register/esm --enable-source-maps bin/test.ts",
    "prepare": "husky",
    "commitlint": "commitlint --edit",
    "commit": "cz"
  },
  "devDependencies": {
    "@arapucajs/tsconfig": "^1.0.0",
    "@commitlint/cli": "^20.5.0",
    "@commitlint/config-conventional": "^20.5.0",
    "@swc/core": "^1.15.24",
    "@t8ngs/assert": "^1.0.0",
    "@t8ngs/expect": "^1.1.0",
    "@t8ngs/fs": "^1.0.0",
    "@t8ngs/runner": "^1.0.1",
    "@types/chai": "^5.2.3",
    "@types/dedent": "^0.7.2",
    "@types/express": "^5.0.6",
    "@types/node": "^25.5.2",
    "@typescript-eslint/eslint-plugin": "^8.29.0",
    "@typescript-eslint/parser": "^8.29.0",
    "c8": "^11.0.0",
    "commitizen": "^4.3.1",
    "cz-conventional-changelog": "^3.3.0",
    "del-cli": "^7.0.0",
    "eslint": "^9.23.0",
    "eslint-config-prettier": "^10.1.1",
    "husky": "^9.1.7",
    "prettier": "^3.5.2",
    "qs": "^6.15.0",
    "ts-node-dev": "^2.0.0",
    "ts-node-maintained": "^10.9.6",
    "tsdown": "^0.21.7",
    "tsup": "^8.5.1",
    "typescript": "^6.0.2"
  },
  "config": {
    "commitizen": {
      "path": "./node_modules/cz-conventional-changelog"
    }
  },
  "keywords": [
    "teko",
    "http",
    "frontend"
  ],
  "author": "Jefte Costa <jefteamorim@gmail.com>",
  "license": "MIT",
  "publishConfig": {
    "access": "public",
    "provenance": true
  },
  "tsup": {
    "entry": [
      "./index.ts",
      "./src/index.ts"
    ],
    "outDir": "./dist",
    "clean": true,
    "format": "esm",
    "dts": false,
    "sourcemap": false,
    "target": "esnext"
  },
  "dependencies": {
    "@tekojs/core": "^2.0.2",
    "@tekojs/ssr": "^1.0.0"
  },
  "peerDependencies": {
    "express": "^5.2.1"
  }
}
